# ── Database ──
POSTGRES_DB=onlinemediatools
POSTGRES_USER=omtuser
POSTGRES_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql://omtuser:changeme_secure_password@postgres:5432/onlinemediatools

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Security ──
SECRET_KEY=changeme_32char_secret_key_here_x
ALLOWED_ORIGINS=http://localhost,https://onlinemediatools.com

# ── Storage ──
STORAGE_PATH=/app/storage
UPLOAD_DIR=/app/storage/uploads
OUTPUT_DIR=/app/storage/outputs
MAX_FILE_SIZE_MB=200
MAX_VIDEO_DURATION_MINUTES=20

# ── Celery ──
CELERY_CONCURRENCY=1

# ── App ──
ENVIRONMENT=production
FRONTEND_URL=https://onlinemediatools.com
API_URL=https://onlinemediatools.com/api
